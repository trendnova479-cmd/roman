<section class="newsletter container" aria-labelledby="newsletter-title">
  <h2 id="newsletter-title">{{ section.settings.title }}</h2>
  <p>{{ section.settings.subtitle }}</p>
  <form method="post" action="/contact#contact_form" accept-charset="UTF-8" class="newsletter-form">
    <input type="email" name="contact[email]" placeholder="Tu correo" required>
    <button type="submit">{{ section.settings.button_text }}</button>
  </form>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "title", "label": "Título", "default": "Suscríbete" },
    { "type": "text", "id": "subtitle", "label": "Subtítulo", "default": "Recibe novedades y ofertas" },
    { "type": "text", "id": "button_text", "label": "Texto botón", "default": "Suscribirme" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
